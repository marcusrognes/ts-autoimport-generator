{
  "name": "ts-autoimport-generator",
  "version": "1.0.6",
  "description": "Generate files with imports based on globs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "tsag": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "ts-node src/index.ts --stripExtension",
    "test:watch": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts watch"
  },
  "author": "Marcus Rognes <marcus@rognes.guru>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcusrognes/ts-autoimport-generator.git"
  },
  "dependencies": {
    "glob": "^11.0.3",
    "glob-watcher": "^6.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/glob-watcher": "^5.0.5",
    "@types/node": "^24.1.0",
    "@types/yargs": "^17.0.33"
  }
}
